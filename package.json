{
  "name": "devdoot",
  "version": "0.0.2",
  "type": "module",
  "description": "High-performance developer diagnostics, structured execution tracing, and global crash reporting engine for Node.js",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "devdoot": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js",
      "require": "./dist/plugins.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/litebyteai/devdoot.git"
  },
  "bugs": {
    "url": "https://github.com/litebyteai/devdoot/issues"
  },
  "homepage": "https://github.com/litebyteai/devdoot#readme",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "example": "tsx examples/demo.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "logging",
    "tracing",
    "diagnostics",
    "observability",
    "crash-reporting",
    "unhandled-exceptions",
    "async-local-storage",
    "context-propagation",
    "performance",
    "developer-experience"
  ],
  "author": "LiteByteAI",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "open": "^11.0.0"
  }
}
